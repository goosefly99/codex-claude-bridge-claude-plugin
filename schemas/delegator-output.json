{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TBD/codex-claude-bridge/schemas/delegator-output.json",
  "title": "DelegationResult",
  "description": "Structured output of a single Codex sub-job invoked by scripts/codex/delegator.ts. The implement-with-codex skill aggregates one or more of these into a user-facing summary.",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "files_changed", "diff_stat", "next_steps"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "error"],
      "description": "Sub-job lifecycle outcome."
    },
    "summary": {
      "type": "string",
      "description": "Two-to-three sentence summary of what the sub-job accomplished.",
      "minLength": 1,
      "maxLength": 2000
    },
    "files_changed": {
      "type": "array",
      "description": "Per-file change record. Paths are forward-slash form normalized through util/paths.toUnixPath.",
      "items": { "$ref": "#/$defs/FileChange" }
    },
    "diff_stat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "insertions", "deletions"],
      "description": "Aggregated git-diff-stat-style totals.",
      "properties": {
        "files": { "type": "integer", "minimum": 0 },
        "insertions": { "type": "integer", "minimum": 0 },
        "deletions": { "type": "integer", "minimum": 0 }
      }
    },
    "next_steps": {
      "type": "array",
      "description": "Short ordered list of follow-up actions the user should take.",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 280
      },
      "maxItems": 12
    },
    "error": {
      "type": "string",
      "description": "Failure detail when status === 'error'. Omitted otherwise.",
      "minLength": 1,
      "maxLength": 2000
    }
  },
  "$defs": {
    "FileChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "lines_added", "lines_removed"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Workspace-relative forward-slash path.",
          "minLength": 1
        },
        "lines_added": { "type": "integer", "minimum": 0 },
        "lines_removed": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
